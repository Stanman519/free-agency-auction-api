# /etc/fantasy-league/auction-api.env  (chmod 600)
# Variables use ASP.NET Core's __ nesting convention (e.g. Auth0__Domain → Auth0:Domain)

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Postgres (Neon)
SqlServerConnectionString=Host=ep-xxx.us-east-1.aws.neon.tech;Database=neondb;Username=xxx;Password=xxx;SSL Mode=Require;Trust Server Certificate=true

# Auth0
Auth0__Domain=
Auth0__Audience=

# Admin
AdminApiKey=

# MFL — rotate by editing this file + docker compose up -d --force-recreate auction-api
Mfl__CommishCookie=MFL_USER_ID=xxx;MFL_IS_COMMISH=xxx
Mfl__MflApiKey__0=
Mfl__MflApiKey__1=

# External APIs
SportsDataConfig__SportsDataApiKey=
StreamClient__StreamKey=
StreamClient__StreamPassword=
BingImageApi__BingSubscriptionKey=

# Cross-service
ServiceUrls__BotApi=https://bot-api.fanpools.net
