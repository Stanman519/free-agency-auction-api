# /etc/fantasy-league/bot-api.env  (chmod 600)

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
# Workstation GC — lower memory footprint on 1 GB Micro (vs default server GC)
DOTNET_gcServer=0

# Postgres (Neon) — note nested ConnectionStrings section
ConnectionStrings__capn-sql-db=Host=ep-xxx.us-east-1.aws.neon.tech;Database=neondb;Username=xxx;Password=xxx;SSL Mode=Require;Trust Server Certificate=true

# MFL
Mfl__CommishCookie=MFL_USER_ID=xxx;MFL_IS_COMMISH=xxx
Mfl__ApiKeys__13894=
Mfl__ApiKeys__26548=

# Cross-service
ServiceUrls__AuctionApi=https://auction-api.fanpools.net
